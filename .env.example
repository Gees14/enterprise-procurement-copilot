# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_SECRET_KEY=change-me-in-production

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_USER=procurement
POSTGRES_PASSWORD=procurement_dev
POSTGRES_DB=procurement_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://procurement:procurement_dev@db:5432/procurement_db

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Leave empty to use MockProvider (no API key required for local dev)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Downloaded automatically on first run from HuggingFace
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Vector Store (ChromaDB) ──────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION=procurement_docs

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
